{
  "name": "endfield-daily-checkin",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "tsx test/index.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"types/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"types/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"types/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"types/*.ts\"",
    "type-check": "tsc --noEmit",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up -d",
    "docker:prod:build": "docker compose build",
    "docker:prod:down": "docker compose down"
  },
  "keywords": [
    "arknights-endfield",
    "endfield-daily-checkin"
  ],
  "author": "NekoCyan",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "mongoose": "^8.23.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
